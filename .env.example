# ---------------------------------------------------------------------------
# Smart Inspect API — SERVER-SIDE ONLY (no VITE_ prefix => never sent to browser)
# Set these in Vercel Project Settings -> Environment Variables.
# ---------------------------------------------------------------------------
# Base URL (default if unset: https://app.mysmartinspect.com/api)
SMART_INSPECT_API_BASE_URL=https://app.mysmartinspect.com/api
# Raw token used as:  Authorization: SIQ-1 <token>
SMART_INSPECT_API_TOKEN=
# Secret for sealing the portal session cookie (AES-256-GCM). Any long random
# string; generate with:  openssl rand -base64 32
SESSION_SECRET=
# Smart Inspect company this portal serves (default 1382 = Wegmans).
SMART_INSPECT_COMPANY_ID=1382

# ---------------------------------------------------------------------------
# Frontend (VITE_ prefix => exposed to browser; keep NON-secret only)
# ---------------------------------------------------------------------------
VITE_APP_ENV=development
# "true" => run entirely on bundled mock data (no API calls).
# "false" => call the /api/smart-inspect proxy (requires SMART_INSPECT_API_TOKEN).
VITE_ENABLE_MOCK_DATA=true
